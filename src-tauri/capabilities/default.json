{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/a2api-sidecar",
          "sidecar": true,
          "args": [
            {
              "validator": ".*dist[/\\\\]server[/\\\\]index\\.js$"
            }
          ]
        }
      ]
    }
  ]
}
